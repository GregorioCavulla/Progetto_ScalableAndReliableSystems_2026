{
    "name": "K8s Cluster Locale (Stabile 2025 - Ubuntu LTS)",
    "build": {
        "dockerfile": "Dockerfile"
    },
    
    "features": {
        // Abilita la funzionalità Docker-in-Docker per far girare i cluster di Kind e costruire container
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "version": "latest",
            "enableNonRootDocker": "true",
            "moby": "true"
        },
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3.10"
        },
        "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
            "version": "latest",
            "helm": "none",
            "minikube": "none"
        }
    },
    
    "postStartCommand": "sudo update-alternatives --set iptables /usr/sbin/iptables-nft && sudo update-alternatives --set ip6tables /usr/sbin/ip6tables-nft && sudo pkill dockerd 2>/dev/null; sudo pkill containerd 2>/dev/null; sleep 1; sudo bash -c 'find /run /var/run -iname docker*.pid -delete 2>/dev/null; nohup dockerd > /tmp/dockerd.log 2>&1 &'; sleep 4; docker info > /dev/null && echo 'Docker OK'",

    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash"
            },
            "extensions": [
                "ms-kubernetes-tools.vscode-kubernetes-tools",
                "ms-azuretools.vscode-docker",
                "redhat.vscode-yaml",
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    },
    
    "remoteUser": "vscode"
}