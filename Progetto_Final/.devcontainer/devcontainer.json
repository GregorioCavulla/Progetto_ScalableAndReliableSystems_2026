{
    "name": "Drone System Beta Environment",
    "image": "mcr.microsoft.com/devcontainers/python:3.10",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {},
        "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {}
    },
    "containerEnv": {
        "OPENAI_API_KEY": "sk-BI1ty8WHJ-PBrVP5_ElhZA"
    },
    "postCreateCommand": "curl -Lo ./kind https://kind.sigs.k8s.io/dl/v0.22.0/kind-linux-amd64 && chmod +x ./kind && sudo mv ./kind /usr/local/bin/kind && pip install paho-mqtt influxdb-client",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-kubernetes-tools.vscode-kubernetes-tools"
            ]
        }
    }
}